# Cross-Review 配置模板
# 复制为 config.yaml 后由 setup.sh 自动填充，或手动编辑
# 首次调用 cross_review 时如果 config.yaml 不存在，会自动运行 setup.sh 生成

# 当前 AI 平台（自动探测：kiro / claude-code / unknown）
platform:

# 交叉审核 MCP 工具名
# - 填写工具名：使用该 MCP 工具作为 Level 1 provider
# - none：跳过 Level 1，直接使用 Subagent（Level 2）
mcp_tool: none

# 专用审核 subagent 名称
# - 填写 agent name：Level 2 使用该 agent 执行审核
# - 留空：使用 default subagent
subagent_name:
