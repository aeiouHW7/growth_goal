generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum GoalStatus {
  ACTIVE
  COMPLETED
  ABANDONED
  ARCHIVED
  SUSPENDED
}

enum PlanStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  PARTIAL
  FAILED
  CANCELLED
}

enum ReviewStatus {
  INPUTTING
  ANALYZING
  COMPLETED
  SKIPPED
}

enum AnalysisType {
  DAILY
  WEEKLY
  MONTHLY
}

enum MetricType {
  NUMERIC
  DURATION
  FREQUENCY
  PERCENTAGE
  STAGE
}

model User {
  id                   String   @id @default(uuid())
  nickname             String?
  age                  Int
  occupation           String
  industry             String
  city                 String?
  weekdayAvailableHours Float
  weekdayTimeBlocks    Json?
  weekendAvailableHours Float
  weekendTimeBlocks    Json?
  goalDomains          String[]
  pastExperience       String?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  lifeGoals    LifeGoal[]
  yearlyGoals  YearlyGoal[]
  monthlyPlans MonthlyPlan[]
  dailyPlans   DailyPlan[]
  dailyReviews  DailyReview[]
  weeklyReviews WeeklyReview[]
  monthlyReviews MonthlyReview[]

  behaviorPatterns  BehaviorPattern[]
  cognitiveBiasLogs CognitiveBiasLog[]
  capabilityScores  CapabilityScore[]
  analysisSessions  AnalysisSession[]
}

model LifeGoal {
  id          String     @id @default(uuid())
  userId      String
  title       String
  description String?
  timeHorizon String?
  status      GoalStatus @default(ACTIVE)
  sortOrder   Int?
  completedAt DateTime?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  user        User        @relation(fields: [userId], references: [id])
  yearlyGoals YearlyGoal[]
}

model YearlyGoal {
  id           String     @id @default(uuid())
  userId       String
  lifeGoalId   String?
  title        String
  description  String?
  year         Int
  metricType   MetricType
  targetValue  String
  currentValue String?
  startValue   String?
  status       GoalStatus @default(ACTIVE)
  completedAt  DateTime?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  user         User         @relation(fields: [userId], references: [id])
  lifeGoal     LifeGoal?    @relation(fields: [lifeGoalId], references: [id])
  monthlyPlans MonthlyPlan[]
}

model MonthlyPlan {
  id           String     @id @default(uuid())
  userId       String
  yearlyGoalId String?
  title        String
  description  String?
  month        Int
  year         Int
  metricType   MetricType
  targetValue  String
  currentValue String?
  startValue   String?
  status       GoalStatus @default(ACTIVE)
  completedAt  DateTime?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  user        User        @relation(fields: [userId], references: [id])
  yearlyGoal  YearlyGoal? @relation(fields: [yearlyGoalId], references: [id])
  dailyPlans  DailyPlan[]
}

model DailyPlan {
  id            String     @id @default(uuid())
  userId        String
  monthlyPlanId String?
  title         String
  description   String?
  date          DateTime
  metricType    MetricType
  targetValue   String
  currentValue  String?
  status        PlanStatus @default(PENDING)
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  user        User         @relation(fields: [userId], references: [id])
  monthlyPlan MonthlyPlan? @relation(fields: [monthlyPlanId], references: [id])
}

model DailyReview {
  id           String       @id @default(uuid())
  userId       String
  date         DateTime
  rawInput     String
  completed    String?
  notCompleted String?
  obstacles    String?
  emotionState String?
  mindsetNote  String?
  energyRate   Int?
  followUpLog  Json?
  status       ReviewStatus @default(INPUTTING)
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  user       User         @relation(fields: [userId], references: [id])
  aiAnalyses AIAnalysis[]

  cognitiveBiasLogs CognitiveBiasLog[]
  analysisSessions  AnalysisSession[]
}

model WeeklyReview {
  id          String       @id @default(uuid())
  userId      String
  weekStart   DateTime
  weekEnd     DateTime
  year        Int
  week        Int
  rawInput    String?
  summary     String?
  missingDays Json?
  status      ReviewStatus @default(INPUTTING)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  user       User         @relation(fields: [userId], references: [id])
  aiAnalyses AIAnalysis[]

  cognitiveBiasLogs CognitiveBiasLog[]
  analysisSessions  AnalysisSession[]
}

model MonthlyReview {
  id          String       @id @default(uuid())
  userId      String
  month       Int
  year        Int
  rawInput    String?
  summary     String?
  missingDays Json?
  status      ReviewStatus @default(INPUTTING)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  user       User         @relation(fields: [userId], references: [id])
  aiAnalyses AIAnalysis[]

  cognitiveBiasLogs CognitiveBiasLog[]
  analysisSessions  AnalysisSession[]
}

model AIAnalysis {
  id              String       @id @default(uuid())
  dailyReviewId   String?
  weeklyReviewId  String?
  monthlyReviewId String?
  analysisType    AnalysisType
  structuredReport Json
  narrativeReport String?
  createdAt       DateTime     @default(now())

  dailyReview   DailyReview?        @relation(fields: [dailyReviewId], references: [id])
  weeklyReview  WeeklyReview?       @relation(fields: [weeklyReviewId], references: [id])
  monthlyReview MonthlyReview?      @relation(fields: [monthlyReviewId], references: [id])
  feedbacks     AIAnalysisFeedback[]
}

model AIAnalysisFeedback {
  id              String   @id @default(uuid())
  aiAnalysisId    String
  userScore       Int
  isPass          Boolean
  isExcellent     Boolean
  excellentReason String?
  failReason      String?
  createdAt       DateTime @default(now())

  aiAnalysis   AIAnalysis      @relation(fields: [aiAnalysisId], references: [id])
  reflections  AIReflection[]
  successCases AISuccessCase[]
}

model AIReflection {
  id                   String   @id @default(uuid())
  feedbackId           String
  issueDescription     String
  improvementDirection String
  isApplied            Boolean  @default(false)
  createdAt            DateTime @default(now())

  feedback AIAnalysisFeedback @relation(fields: [feedbackId], references: [id])
}

model AISuccessCase {
  id                  String   @id @default(uuid())
  feedbackId          String
  excellentPattern    String
  replicableCondition String?
  createdAt           DateTime @default(now())

  feedback AIAnalysisFeedback @relation(fields: [feedbackId], references: [id])
}

// ===== self-growth-analyst 引擎模型 =====

/// 跨天行为模式追踪（替换 retrieval_index.json）
model BehaviorPattern {
  id            String   @id @default(uuid())
  userId        String
  pattern       String
  dimension     String?
  keywords      String[]
  firstDetected DateTime
  lastDetected  DateTime
  frequency     Int      @default(1)
  active        Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user User @relation(fields: [userId], references: [id])
}

/// 认知偏误日志（替换 cognitive_bias_log.md）
model CognitiveBiasLog {
  id            String   @id @default(uuid())
  userId        String
  dailyReviewId String?
  weeklyReviewId String?
  monthlyReviewId String?
  biasType      String
  triggerPhrase String
  evidence      String
  createdAt     DateTime @default(now())

  user         User         @relation(fields: [userId], references: [id])
  dailyReview  DailyReview?  @relation(fields: [dailyReviewId], references: [id])
  weeklyReview  WeeklyReview? @relation(fields: [weeklyReviewId], references: [id])
  monthlyReview MonthlyReview? @relation(fields: [monthlyReviewId], references: [id])
}

/// 能力维度评分（替换 dynamic_baseline.json）
model CapabilityScore {
  id        String   @id @default(uuid())
  userId    String
  dimension String
  score     Float
  evidence  String?
  source    String   @default("daily_review")
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])
}

/// 分析会话状态（替换 orchestrator_state.json）
model AnalysisSession {
  id          String   @id @default(uuid())
  userId      String
  dailyReviewId String?
  weeklyReviewId String?
  monthlyReviewId String?
  status      String   @default("idle")
  currentStep String?
  result      Json?
  startedAt   DateTime @default(now())
  completedAt DateTime?

  user         User         @relation(fields: [userId], references: [id])
  dailyReview  DailyReview?  @relation(fields: [dailyReviewId], references: [id])
  weeklyReview  WeeklyReview? @relation(fields: [weeklyReviewId], references: [id])
  monthlyReview MonthlyReview? @relation(fields: [monthlyReviewId], references: [id])
}
