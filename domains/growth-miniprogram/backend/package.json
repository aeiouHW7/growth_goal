{
  "name": "growth-miniprogram-backend",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "bash ../scripts/db-backup.sh pre-dev 2>/dev/null; tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:seed": "echo '⚠️  已禁用。如需重建，请运行: npx tsx prisma/seed.ts --force' && exit 1",
    "db:backup": "bash ../scripts/db-backup.sh",
    "db:restore": "bash ../scripts/db-restore.sh",
    "typecheck": "tsc --noEmit",
    "lint": "eslint --quiet .",
    "test": "jest --passWithNoTests"
  },
  "dependencies": {
    "@prisma/client": "^6.5.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/jest": "^29.5.14",
    "@types/node": "^22.10.0",
    "@types/supertest": "^7.2.0",
    "jest": "^29.7.0",
    "nodemon": "^3.1.7",
    "prisma": "^6.5.0",
    "supertest": "^7.2.2",
    "ts-jest": "^29.2.5",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "roots": [
      "<rootDir>/src"
    ]
  }
}
